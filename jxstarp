-- fps and ping fix
local fpsDisplayGui = nil
local fpsUpdateConnection = nil
local lastTick = tick()
local frameCount = 0
local currentFPS = 0

local function createFPSDisplay()
    if fpsDisplayGui then return end
   
    fpsDisplayGui = Instance.new("ScreenGui")
    fpsDisplayGui.Name = "JXStarpFPS"
    fpsDisplayGui.ResetOnSpawn = false
    fpsDisplayGui.DisplayOrder = 999
    fpsDisplayGui.Parent = player:WaitForChild("PlayerGui")
   
    local frame = Instance.new("Frame")
    frame.Size = UDim2.new(0, 220, 0, 28)
    frame.Position = UDim2.new(0, 12, 0, 8)
    frame.BackgroundTransparency = 0.4
    frame.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
    frame.BorderSizePixel = 0
    frame.Parent = fpsDisplayGui
   
    local corner = Instance.new("UICorner")
    corner.CornerRadius = UDim.new(0, 6)
    corner.Parent = frame
   
    local label = Instance.new("TextLabel")
    label.Size = UDim2.new(1, 0, 1, 0)
    label.BackgroundTransparency = 1
    label.Text = "FPS: 0 | Ping: 0 ms"
    label.TextColor3 = Color3.fromRGB(255, 255, 255)
    label.TextScaled = true
    label.Font = Enum.Font.GothamBold
    label.TextXAlignment = Enum.TextXAlignment.Left
    label.TextStrokeTransparency = 0.7
    label.Parent = frame
end

local function updateFPSText()
    frameCount += 1
    local currentTime = tick()
    if currentTime - lastTick >= 1 then
        currentFPS = frameCount
        frameCount = 0
        lastTick = currentTime
    end
   
    local ping = 0
    pcall(function()
        ping = game:GetService("Stats").Network.ServerStatsItem["Data Ping"]:GetValue()
    end)
   
    if fpsDisplayGui then
        local label = fpsDisplayGui:FindFirstChildWhichIsA("TextLabel")
        if label then
            label.Text = string.format("FPS: %d | Ping: %d ms", math.floor(currentFPS), math.floor(ping))
        end
    end
end

-- no face sky ground - face removed but head stays skin color
local function applyNoFaceSkyGround()
    for _, v in ipairs(Lighting:GetChildren()) do
        if v:IsA("Sky") or v:IsA("Atmosphere") then
            v:Destroy()
        end
    end
    
    if player.Character then
        local char = player.Character
        for _, v in ipairs(char:GetDescendants()) do
            if v:IsA("FaceInstance") or (v.Name == "face" and v:IsA("Decal")) then
                v:Destroy()
            end
        end
        
        local head = char:FindFirstChild("Head")
        if head then
            head.Material = Enum.Material.Plastic
            local bodyColors = char:FindFirstChild("BodyColors")
            if bodyColors then
                head.Color = bodyColors.HeadColor3
            end
        end
    end
    
    local function stripGround(obj)
        for _, v in ipairs(obj:GetDescendants()) do
            if v:IsA("Texture") or v:IsA("Decal") or v:IsA("SurfaceAppearance") or v:IsA("SpecialMesh") then
                local parentPart = v.Parent
                if parentPart and parentPart:IsA("BasePart") and (parentPart.Position.Y < 20 or string.lower(parentPart.Name):find("ground") or string.lower(parentPart.Name):find("floor") or string.lower(parentPart.Name):find("field") or string.lower(parentPart.Name):find("grass")) then
                    v:Destroy()
                end
            elseif v:IsA("BasePart") or v:IsA("MeshPart") then
                if v.Position.Y < 20 or string.lower(v.Name):find("ground") or string.lower(v.Name):find("floor") or string.lower(v.Name):find("field") or string.lower(v.Name):find("grass") then
                    v.Material = Enum.Material.SmoothPlastic
                    v.Reflectance = 0
                end
            end
        end
    end
    
    stripGround(workspace)
    
    Rayfield:Notify({
        Title = "No Face Sky Ground",
        Content = "Face removed, head is skin color, sky and ground textures gone",
        Duration = 5
    })
end

