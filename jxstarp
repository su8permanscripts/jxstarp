local FontsTab = Window:CreateTab("Fonts", 4483362458)
local currentFont = Enum.Font.Gotham
local fontConnection = nil
local function applyFontToObject(obj)
    if obj:IsA("TextLabel") or obj:IsA("TextButton") or obj:IsA("TextBox") then
        pcall(function() obj.Font = currentFont end)
    end
end
local function applyFontGlobally()
    for _, obj in ipairs(game:GetDescendants()) do
        applyFontToObject(obj)
    end
    if fontConnection then fontConnection:Disconnect() end
    fontConnection = game.DescendantAdded:Connect(function(obj)
        task.wait()
        applyFontToObject(obj)
    end)
end
local function setGlobalFont(fontEnum)
    currentFont = fontEnum
    applyFontGlobally()
    Rayfield:Notify({Title = "Global Font", Content = "Applied to entire game", Duration = 4})
end
